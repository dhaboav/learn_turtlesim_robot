<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Other xacro files -->
    <xacro:include filename="materials.urdf.xacro" />
    <xacro:include filename="inertials.urdf.xacro" />

    <!-- Xacro properties -->
    <xacro:property name="radius_wheels" value="0.1" />
    <xacro:property name="radius_caster_wheel" value="0.05" />
    <xacro:property name="length" value="0.05" />

    <!-- Xacro links -->
    <xacro:macro name="wheels" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${radius_wheels}" length="${length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="1.57 0 0" />
                <material name="grey" />
            </visual>

            <collision>
                <geometry>
                    <cylinder radius="${radius_wheels}" length="${length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="1.57 0 0" />
            </collision>
            <xacro:solid_cylinder_inertia 
                mass="0.5" radius="${radius_wheels}" length="${length}" 
                xyz="0 0 0" rpy="1.57 0 0" />
        </link>
    </xacro:macro>
    
    <!-- Xacro joints -->
    <xacro:macro name="fixed_joint" params="prefix parent child xyz rpy">
        <joint name="${prefix}_joint" type="fixed">
            <parent link="${parent}" />
            <child link="${child}" />
            <origin xyz="${xyz}" rpy="${rpy}" />
        </joint>
    </xacro:macro>

    <xacro:macro name="continuous_joint" params="prefix parent child xyz rpy axis">
        <joint name="${prefix}_joint" type="continuous">
            <parent link="${parent}" />
            <child link="${child}" />
            <origin xyz="${xyz}" rpy="${rpy}" />
            <axis xyz="${axis}" />
        </joint>
    </xacro:macro>

    <!-- Links Section -->
    <link name="base_link" />
    <link name="main_body_link">
        <visual>
            <geometry>
                <box size="0.6 0.4 0.2" />
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0" />
            <material name="green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.6 0.4 0.2" />
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0" />
        </collision>
        <xacro:solid_box_inertia 
            mass="5" x="0.6" y="0.4" z="0.2" 
            xyz="0 0 0.1" rpy="0 0 0"/>
    </link>

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="${radius_wheels}" length="${length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="white" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${radius_wheels}" length="${length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
    </link>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${radius_caster_wheel}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <sphere radius="${radius_caster_wheel}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:solid_sphere_inertia mass="0.2" radius="${radius_caster_wheel}"/>
    </link>
    <xacro:wheels prefix="left" />
    <xacro:wheels prefix="right" />

    <!-- Joints Section-->
    <xacro:fixed_joint 
        prefix="base" 
        parent="base_link" 
        child="main_body_link" 
        xyz="0 0 0.1" rpy="0 0 0"/>

    <xacro:fixed_joint 
        prefix="base_lidar" 
        parent="main_body_link" 
        child="lidar_link" 
        xyz="0 0 0.225" rpy="0 0 0"/>

    <xacro:fixed_joint 
        prefix="base_caster_wheel" 
        parent="main_body_link" 
        child="caster_wheel_link" 
        xyz="0.2 0 -0.025" rpy="0 0 0" />

    <xacro:continuous_joint 
        prefix="base_left_wheel" 
        parent="main_body_link" 
        child="left_wheel_link" 
        xyz="-0.15 0.225 0" rpy="0 0 0" 
        axis="0 1 0"/>

    <xacro:continuous_joint 
        prefix="base_right_wheel" 
        parent="main_body_link" 
        child="right_wheel_link" 
        xyz="-0.15 -0.225 0" rpy="0 0 0" 
        axis="0 1 0"/>

    <!-- Gazebo Section -->
    <gazebo>
        <plugin
            filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">

            <left_joint>base_left_wheel_joint</left_joint>
            <right_joint>base_right_wheel_joint</right_joint>

            <wheel_separation>0.45</wheel_separation>
            <wheel_radius>${radius_wheels}</wheel_radius>

            <topic>cmd_vel</topic>

        </plugin>
    </gazebo>

    <!-- Lidar sensor -->
    <gazebo>
        <plugin
            filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
    </gazebo>

    <gazebo reference="lidar_link">
        <sensor name="gpu_lidar" type="gpu_lidar">
            <pose relative_to="lidar_link">0 0 0 0 0 0</pose>
            <topic>lidar</topic>
            <update_rate>2</update_rate>

            <lidar>
                <scan>
                    <horizontal>
                        <samples>720</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14</min_angle>
                        <max_angle>3.14</max_angle>
                    </horizontal>
                </scan>

                <range>
                    <min>0.01</min>
                    <max>12.0</max>
                    <resolution>0.005</resolution>
                </range>

                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.001</stddev>
                </noise>     
            </lidar>

            <always_on>1</always_on>
            <visualize>1</visualize>
        </sensor>
    </gazebo>

</robot>
