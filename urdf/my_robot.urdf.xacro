<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">

    <!-- Other xacro files -->
    <xacro:include filename="materials.urdf.xacro" />

    <!-- Xacro properties -->
    <xacro:property name="radius" value="0.1" />
    <xacro:property name="length" value="0.05" />

    <!-- Xacro links -->
    <xacro:macro name="wheels" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${radius}" length="${length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="1.57 0 0" />
                <material name="grey" />
            </visual>
        </link>
    </xacro:macro>
    
    <!-- Xacro joints -->
    <xacro:macro name="fixed_joint" params="prefix parent child xyz rpy">
        <joint name="${prefix}_joint" type="fixed">
            <parent link="${parent}" />
            <child link="${child}" />
            <origin xyz="${xyz}" rpy="${rpy}" />
        </joint>
    </xacro:macro>

    <xacro:macro name="continuous_joint" params="prefix parent child xyz rpy axis">
        <joint name="${prefix}_joint" type="continuous">
            <parent link="${parent}" />
            <child link="${child}" />
            <origin xyz="${xyz}" rpy="${rpy}" />
            <axis xyz="${axis}" />
        </joint>
    </xacro:macro>
     
    <!-- Links Section -->
    <link name="base_link" />
    <link name="main_body_link">
        <visual>
            <geometry>
                <box size="0.6 0.4 0.2" />
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0" />
            <material name="green" />
        </visual>
    </link>

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="${radius}" length="${length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="white" />
        </visual>
    </link>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${radius}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
    </link>
    <xacro:wheels prefix="left" />
    <xacro:wheels prefix="right" />

    <!-- Joints Section-->
    <xacro:fixed_joint prefix="base" parent="base_link" child="main_body_link" xyz="0 0 0.1" rpy="0 0 0"/>
    <xacro:fixed_joint prefix="base_lidar" parent="main_body_link" child="lidar_link" xyz="0 0 0.225" rpy="0 0 0"/>
    <xacro:fixed_joint prefix="base_caster_wheel" parent="main_body_link" child="caster_wheel_link" xyz="0.2 0 -0.05" rpy="0 0 0" />
    <xacro:continuous_joint prefix="base_left_wheel" parent="main_body_link" child="left_wheel_link" xyz="-0.15 0.225 0" rpy="0 0 0" axis="0 1 0"/>
    <xacro:continuous_joint prefix="base_right_wheel" parent="main_body_link" child="right_wheel_link" xyz="-0.15 -0.225 0" rpy="0 0 0" axis="0 1 0"/>
   
</robot>
